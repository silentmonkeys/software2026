DASHSCOPE_API_KEY=sk-密钥  #前往阿里云获取
# 生产必须改为强随机值：python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=please-change-me
# 仅开发/测试绕过默认 JWT_SECRET 强制校验；生产保持 false
ALLOW_INSECURE_JWT=false
DB_URL=sqlite:///./loongchip.db
CHROMA_DIR=./chroma_db
UPLOAD_DIR=./uploads
DEBUG=false
# 逗号分隔的允许跨域来源；生产请改为前端实际域名，如 https://maintain.example.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
