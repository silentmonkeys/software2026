# =========================================================
# docker compose 部署用变量（仅 compose 自身使用，不参与前端构建）
# 复制为 .env 后按需修改：cp .env.example .env
# =========================================================

# 前端对外端口（宿主机端口）。默认 8080。
# 同网段访问 → http://<服务器IP>:${HOST_PORT}
HOST_PORT=8080

# 绑定网卡。默认 0.0.0.0 = 所有网卡（局域网可达）。
# 若只想本机访问：127.0.0.1
# IPv6：::
BIND_ADDR=0.0.0.0

# 调试用：把后端 8000 端口也对外暴露（默认注释在 docker-compose.yml 中）
# 启用方式：取消 docker-compose.yml 中 backend 段 ports 的注释
BACKEND_PORT=8000
